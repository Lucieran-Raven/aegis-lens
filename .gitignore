# Aegis Lens Monorepo .gitignore

# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# IDE & Editor Files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# =============================================================================
# Rust / Cargo
# =============================================================================
target/
Cargo.lock
**/*.rs.bk
*.pdb
pkg/
wasm-pack.log

# =============================================================================
# Node.js / JavaScript / TypeScript
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
dist/
dist-ssr/
*.local
.eslintcache
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/
.tern-port
*.tsbuildinfo

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
*.mo
*.pot

# =============================================================================
# Docker
# =============================================================================
*.log
docker-compose.override.yml

# =============================================================================
# Kubernetes
# =============================================================================
*.kubeconfig
kubeconfig

# =============================================================================
# Environment Variables & Secrets
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.crt
secrets/
*.secret

# =============================================================================
# Database
# =============================================================================
*.db
*.sqlite
*.sqlite3
data/
pgdata/
redis-data/
neo4j-data/
timescale-data/

# =============================================================================
# Model Files (AI/ML)
# =============================================================================
*.pt
*.pth
*.onnx
*.h5
*.pkl
*.pickle
*.joblib
models/
checkpoints/
wandb/
mlruns/

# =============================================================================
# Test Coverage
# =============================================================================
coverage/
*.lcov
.nyc_output/

# =============================================================================
# Build Artifacts
# =============================================================================
*.wasm
*.a
*.o
*.lib
*.dll
*.dylib
*.exe
*.out
*.app

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.backup
.cache/

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Package Manager Lock Files (keep some, ignore others)
# =============================================================================
# Keep package-lock.json and yarn.lock for reproducibility
# Ignore Python lock files if using pip-tools
*.egg-info/

# =============================================================================
# Project History & Documentation
# =============================================================================
PROJECT_HISTORY.txt
