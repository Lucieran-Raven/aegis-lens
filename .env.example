# AEGIS LENS - Environment Variables Configuration
# Copy this file to .env and update with your values
# DO NOT commit .env to version control

# ==================== Application ====================
APP_ENV=development
APP_NAME=aegis-lens
APP_VERSION=0.1.0
APP_DEBUG=true
APP_URL=http://localhost:3000
API_PORT=8000

# ==================== Database - PostgreSQL ====================
PG_HOST=localhost
PG_PORT=5432
PG_USER=aegis
PG_PASSWORD=your_secure_postgres_password
PG_DATABASE=aegis
PG_SSL=false
PG_POOL_SIZE=20
PG_MAX_OVERFLOW=10

# ==================== Database - TimescaleDB ====================
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_USER=aegis
TIMESCALE_PASSWORD=your_secure_timescale_password
TIMESCALE_DATABASE=aegis_metrics
TIMESCALE_SSL=false

# ==================== Database - Neo4j ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_neo4j_password
NEO4J_ENCRYPTION=false

# ==================== Database - Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50

# ==================== API Keys ====================
# OpenAI API (for AI/ML features)
OPENAI_API_KEY=your_openai_api_key_here

# External services (if needed)
# SLACK_WEBHOOK_URL=
# SENTRY_DSN=

# ==================== Security ====================
# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys for external integrations
# CANDIDATE_SOURCE_API_KEY=
# JOB_BOARD_API_KEY=

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# ==================== Monitoring ====================
# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Health check
HEALTH_CHECK_ENABLED=true

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ==================== File Upload ====================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,doc,docx,txt
UPLOAD_PATH=uploads/

# ==================== Email (Optional) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aegis-lens.com
SMTP_USE_TLS=true

# ==================== Session ====================
SESSION_SECRET=your_session_secret_key
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_EXPIRATION_HOURS=24

# ==================== Feature Flags ====================
FEATURE_AI_ANALYSIS=true
FEATURE_VOICE_ANALYSIS=true
FEATURE_BEHAVIORAL_ANALYSIS=true
FEATURE_KNOWLEDGE_GRAPH=true
FEATURE_REAL_TIME_STREAMING=true
